{% block body %}
<div style="font-family: Arial, sans-serif; color: #0f172a; line-height: 1.6;">
    <h2 style="margin-bottom: 16px;">Recuperação de senha</h2>

    <p>
        Recebemos uma solicitação para redefinir a senha da sua conta em {{ app_name }}.
    </p>

    <p>
        Para continuar, clique no botão abaixo:
    </p>

    <p style="margin: 24px 0;">
        <a
            href="{{ reset_url }}"
            style="display: inline-block; background: #2563eb; color: #ffffff; text-decoration: none; padding: 12px 20px; border-radius: 8px; font-weight: bold;"
        >
            Redefinir senha
        </a>
    </p>

    <p>
        Se preferir, copie e cole este link no navegador:
    </p>

    <p>
        <a href="{{ reset_url }}">{{ reset_url }}</a>
    </p>

    <p>
        Este link expira em 15 minutos. Se você não solicitou a alteração, pode ignorar esta mensagem.
    </p>
</div>
{% endblock %}
